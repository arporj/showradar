# Postgres connection string for this app's dedicated Supabase project, pointed at
# its schema (showradar). Pick a region close to your users (this project uses
# sa-east-1 / São Paulo). Use the "Transaction" connection pooler string (port 6543)
# — required for serverless/Vercel deployments.
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> Transaction pooler.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Auth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
# and https://<your-domain>/api/auth/callback/google (prod).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# TMDb v4 Read Access Token (themoviedb.org -> Settings -> API -> API Read Access Token).
TMDB_ACCESS_TOKEN=""

# Base URL of the app (used for building absolute links, e.g. in emails).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google tag (gtag.js) for Google Ads / GA4 — optional. The tag only loads when
# this is set (see components/analytics/google-tag.tsx). Use the measurement ID
# from Google Ads (AW-XXXXXXX) or GA4 (G-XXXXXXX); the sign_up event fired after
# account creation can then be imported as an Ads conversion.
NEXT_PUBLIC_GOOGLE_TAG_ID=""

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# Contact the push service (browser vendor) can reach if this server is
# misbehaving — required by the Web Push protocol, not a public-facing value.
VAPID_SUBJECT="mailto:you@example.com"

# Bearer secret the daily cron route (app/api/cron/check-new-releases) checks
# for — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=""

# Brevo (transactional email) — used for password-reset links.
# Brevo Dashboard -> SMTP & API -> API Keys.
BREVO_API_KEY=""
# Verified sender identity (Brevo Dashboard -> Senders, Domains & Dedicated IPs).
BREVO_SENDER_EMAIL="showradar@andreric.com"
BREVO_SENDER_NAME="ShowRadar"

# Supabase Storage (profile photo uploads) — separate from DATABASE_URL, which
# points at the pooler host, not the project's REST/Storage API host.
# Supabase Dashboard -> Project Settings -> API -> Project URL.
SUPABASE_URL="https://[project-ref].supabase.co"
# Supabase Dashboard -> Project Settings -> API -> service_role secret key.
# Server-only — grants full bucket/table access, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""
